# ─── 数据库 ───────────────────────────────────────────────
# SQLite 连接字符串。mode=rwc 表示读写创建模式（文件不存在时自动创建）。
# 生产环境：确保 data/ 目录已持久化并定期备份。
DATABASE_URL=sqlite://./data/steel_pipe.db?mode=rwc

# ─── JWT 认证 ─────────────────────────────────────────────
# JWT 签名的 HMAC 密钥。生产环境必须修改！
# 生成方式：openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret

# JWT 令牌过期时间（小时）。默认：24（一天）
JWT_EXPIRY_HOURS=24

# ─── 服务器 ───────────────────────────────────────────────
# HTTP 服务器绑定的网络接口。默认：0.0.0.0（所有接口）
# 生产环境建议设为 127.0.0.1（仅本地，配合反向代理使用）
SERVER_HOST=0.0.0.0

# HTTP 服务器端口。默认：3000
SERVER_PORT=3000

# ─── CORS 跨域 ─────────────────────────────────────────────
# 允许的前端域名，多个用逗号分隔。默认：http://localhost:5173（Vite 开发服务器）
# 生产环境示例：https://pipe.example.com,https://pipe2.example.com
CORS_ORIGINS=http://localhost:5173

