# 后端环境变量配置
# 复制此文件为 .env 并修改

# SQLite 数据库路径（:mode? 参数: rwc = 读写+创建）
DATABASE_URL=sqlite:./data/pipe_management.db?mode=rwc

# JWT 密钥（生产环境务必修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Access Token 有效期（秒，默认 1 小时）
JWT_ACCESS_EXPIRY=3600

# Refresh Token 有效期（秒，默认 30 天）
JWT_REFRESH_EXPIRY=2592000

# 上传文件存储目录
UPLOAD_DIR=./uploads
